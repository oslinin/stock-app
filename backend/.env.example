# ---- server ----
# Empty API_TOKEN disables auth (dev only). Set a long random string in production.
API_TOKEN=
CORS_ORIGINS=http://localhost:5173,https://oslinin.github.io
DB_URL=sqlite:///./vix_screener.db

# ---- Interactive Brokers ----
IBKR_ENABLED=true
IBKR_HOST=127.0.0.1
# 4002 = IB Gateway paper, 4001 = IB Gateway live, 7497 = TWS paper, 7496 = TWS live.
# In the docker-compose deployment the gateway publishes paper on 4004 / live on 4003 (socat).
IBKR_PORT=4002
IBKR_CLIENT_ID=11
IBKR_MODE=paper
IBKR_USE_DELAYED=true
# Hard gate for order staging. Keep false until you have reviewed the flow in paper trading.
ALLOW_ORDER_STAGING=false

# ---- alerts (SMTP; Gmail app passwords work) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM=
DEFAULT_ALERT_EMAIL=oleg.slinin@gmail.com
# Optional push channel: full ntfy topic URL, e.g. https://ntfy.sh/your-secret-topic
NTFY_URL=

# ---- scheduler ----
SCHEDULER_ENABLED=true

# ---- market data providers (phase 2) ----
# Free key: https://www.alphavantage.co/support/#api-key (25 requests/day).
# Leave empty to skip registering the provider.
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_DAILY_BUDGET=25
# Symbols the nightly iv_snapshot job keeps ATM-IV history for (IV rank).
# Synced from IBKR's IV index (needs the gateway); first run backfills ~1y.
IV_SNAPSHOT_SYMBOLS=SPY,QQQ,IWM
# Risk-free rate used for Black-Scholes greeks/IV enrichment.
ANALYTICS_RISK_FREE_RATE=0.04

# ---- VIX hedge strategy defaults ----
VIX_MACD_FAST=12
VIX_MACD_SLOW=26
VIX_MACD_SIGNAL=9
VIX_OR_MINUTES=30
VIX_SPREAD_WIDTH=1.0
VIX_NET_DEBIT_CAP_USD=100
VIX_DTE_MIN=15
VIX_DTE_MAX=34
VIX_LOW_LOOKBACK_DAYS=120
VIX_LOW_QUANTILE=0.4
VIX_ABS_LOW=20.0
VIX_ARMED_TTL_DAYS=4
VIX_STRIKE_WINDOW_BELOW=8.0
VIX_STRIKE_WINDOW_ABOVE=5.0
