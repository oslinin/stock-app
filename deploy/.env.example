# ---- domain / TLS (point an A record for this host at the VPS first) ----
DOMAIN=vix.example.com

# ---- IBKR credentials for the headless gateway (IBC auto-login) ----
# 2FA note: IB mobile-app 2FA prompts on login; TWOFA_TIMEOUT_ACTION=restart
# retries until you approve. Consider a dedicated user for the bot session.
TWS_USERID=your_ib_username
TWS_PASSWORD=your_ib_password
TRADING_MODE=paper            # paper | live
READ_ONLY_API=no              # 'yes' blocks even staged orders at the gateway level

# ---- backend ----
# Long random string; the frontend sends it as Authorization: Bearer <token>.
# Generate one with: openssl rand -base64 33
API_TOKEN=change-me
CORS_ORIGINS=https://oslinin.github.io,http://localhost:5173
IBKR_ENABLED=true
IBKR_PORT=4004                # 4004 = paper, 4003 = live (socat bridge in the image)
IBKR_CLIENT_ID=11
IBKR_MODE=paper
IBKR_USE_DELAYED=true         # set false once CBOE/OPRA market data is subscribed
ALLOW_ORDER_STAGING=false     # keep false until the flow is proven in paper
SCHEDULER_ENABLED=true

# ---- alerts ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_gmail_app_password
ALERT_FROM=you@gmail.com
DEFAULT_ALERT_EMAIL=oleg.slinin@gmail.com
NTFY_URL=

# ---- strategy overrides (defaults shown; delete lines to use built-ins) ----
VIX_SPREAD_WIDTH=1.0
VIX_NET_DEBIT_CAP_USD=100
VIX_DTE_MIN=15
VIX_DTE_MAX=34
VIX_OR_MINUTES=30
